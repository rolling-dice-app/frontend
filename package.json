{
  "name": "@rolling-dice-app/frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "git config core.hooksPath .githooks",
    "type-check": "nuxi typecheck",
    "lint": "run-s lint:oxlint lint:eslint",
    "lint:check": "run-s lint:oxlint:check lint:eslint:check",
    "lint:eslint": "eslint --fix --cache .",
    "lint:eslint:check": "eslint --cache .",
    "lint:oxlint": "oxlint --fix .",
    "lint:oxlint:check": "oxlint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest",
    "test:unit:ci": "vitest --run",
    "test:coverage": "vitest --coverage",
    "init:ui": "git submodule update --init packages/ui && pnpm update:ui",
    "update:ui": "git submodule update --remote packages/ui && cd packages/ui && pnpm install --ignore-workspace && pnpm build && cd ../.. && git add packages/ui"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@rolling-dice-app/core": "^9.4.1",
    "@tailwindcss/vite": "^4.3.0",
    "nuxt": "^4.4.5",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-advanced-cropper": "^2.8.9",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/test-utils": "3.23.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.65.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.65.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.9"
  },
  "lint-staged": {
    "*.{ts,vue,tsx,mts}": [
      "oxlint --fix",
      "eslint --fix --cache"
    ],
    "*.{ts,vue,tsx,mts,css,json,yaml,yml,md}": [
      "prettier --write"
    ]
  }
}
